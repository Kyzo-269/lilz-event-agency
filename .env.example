# ============================================================
# LIL'Z EVENT AGENCY — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Récupérer depuis : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_publique

# ── Notifications Push VAPID ─────────────────────────────────
# Générer avec : node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2));"
# OU : npx web-push generate-vapid-keys

# Clé publique (exposée au client, sans danger)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=votre_cle_publique_vapid

# Clé privée (serveur uniquement — NE JAMAIS exposer côté client)
VAPID_PRIVATE_KEY=votre_cle_privee_vapid

# Contact (email ou URL de votre site)
VAPID_SUBJECT=mailto:contact@lilzeventagency.com
