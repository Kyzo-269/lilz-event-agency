# ============================================================
# LIL'Z EVENT AGENCY — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Récupérer depuis : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_publique

# ── (Optionnel) Pour les notifications push VAPID ────────────
# Générer avec : npx web-push generate-vapid-keys
# À ajouter côté serveur uniquement (pas NEXT_PUBLIC)
# VAPID_PUBLIC_KEY=votre_cle_publique_vapid
# VAPID_PRIVATE_KEY=votre_cle_privee_vapid
# VAPID_SUBJECT=mailto:contact@lilzeventagency.com
